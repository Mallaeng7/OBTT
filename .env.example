# ── 필수 (봇) ─────────────────────────────────────
DISCORD_TOKEN=
DISCORD_CLIENT_ID=

# ── 필수 (웹 대시보드 / 인증) ──────────────────────
# 대시보드 공개 URL (배포 시 https://도메인, 로컬은 http://localhost:3000)
WEB_BASE_URL=http://localhost:3000
PORT=3000
# https://steamcommunity.com/dev/apikey 에서 발급
STEAM_API_KEY=
STEAM_RETURN_URL=http://localhost:3000/api/auth/steam/return
# 32자 이상 랜덤 문자열
SESSION_SECRET=
# 최고 관리자 SteamID64 (쉼표 구분)
ADMIN_STEAM_IDS=

# ── 선택 ─────────────────────────────────────────
LANGUAGE=ko
POLLING_INTERVAL_MS=10000
DATABASE_PATH=data/obtt.db
